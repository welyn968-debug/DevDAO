{
  "name": "devdao",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "turbo run db:migrate",
    "contracts:test": "pnpm --filter @devdao/contracts test"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^1.13.0",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7",
    "prettier": "^3.2.5"
  }
}
